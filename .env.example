# Reverse proxy (nginx-proxy + letsencrypt)
VIRTUAL_HOST=tracker.ton-domaine.fr
LETSENCRYPT_EMAIL=ton@email.fr

# Base de données (réseau cedpich-db, conteneur cedpich-postgis-db)
# Valeurs à copier depuis D:\Docker\PostGIS\.env :
#   DB_USER     = DB_USER_TRACTOR_TRACKER
#   DB_PASSWORD = DB_PASS_TRACTOR_TRACKER
DB_NAME=tractor_tracker
DB_USER=tractor_tracker_user
DB_PASSWORD=changeme

# Seuil d'inactivité avant notification push (défaut : 4h)
#INACTIVITY_THRESHOLD_HOURS=4

# Log fichier du JSON brut reçu au webhook (défaut : true)
#ENABLE_WEBHOOK_RAW_LOG=true

# Notifications push (VAPID) — générer avec : npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:ton@email.fr
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

